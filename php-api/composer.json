{
  "name": "vivien/vivien-api",
  "description": "Vivien loyalty and gift-card API",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "endroid/qr-code": "^6.0",
    "guzzlehttp/guzzle": "^7.9",
    "monolog/monolog": "^3.8",
    "nyholm/psr7": "^1.8",
    "nyholm/psr7-server": "^1.1",
    "slim/slim": "^4.14",
    "stripe/stripe-php": "^20.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Vivien\\Api\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vivien\\Api\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "check": [
      "@php bin/check.php",
      "@test"
    ]
  }
}
