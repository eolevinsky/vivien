APP_ENV=development
APP_DEBUG=false
PUBLIC_BASE_URL=http://localhost:8080
WEBSITE_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,https://vivien.lv,https://www.vivien.lv

DB_HOST=localhost
DB_PORT=3306
DB_NAME=vivien_loyalty
DB_USER=vivien_loyalty
DB_PASSWORD=replace_me

STRIPE_SECRET_KEY=replace_with_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

PASSSLOT_MODE=mock
PASSSLOT_API_KEY=replace_me
PASSSLOT_TEMPLATE_ID=6670122238476288
PASSSLOT_EXPECTED_TYPE_IDENTIFIER=pass.loyalty
PASSSLOT_BALANCE_FIELD=points

SYRVE_MODE=mock
SYRVE_BASE_URL=https://api-eu.syrve.live
SYRVE_API_LOGIN=replace_me
SYRVE_ORGANIZATION_ID=fecb3371-8475-4df5-92c8-4dae76a83a88
SYRVE_LOYALTY_PREFIX=syrve
SYRVE_WEBHOOK_SECRET=replace_with_a_long_random_secret

INTERNAL_JOB_SECRET=replace_with_a_different_long_random_secret
INTERNAL_ADMIN_SECRET=replace_with_an_optional_admin_secret
FULFILLMENT_DEADLINE_MINUTES=120
MAX_REQUEST_BYTES=1048576
CHECKOUT_IP_RATE_LIMIT=30
CHECKOUT_RATE_LIMIT=10
CHECKOUT_RATE_WINDOW_SECONDS=900
JOB_BATCH_SIZE=5
JOB_RUN_BUDGET_SECONDS=20
LOG_PATH=var/api.log
