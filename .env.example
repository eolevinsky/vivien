# Python reference implementation only.
# Production Plesk PHP API uses php-api/.env.example.
# Static site builds use site-v2/.env.example.
# Copy to .env for local Python development only. Never commit real values.
VIVIEN_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./data/vivien.db

STRIPE_SECRET_KEY=replace_with_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# "mock" exercises the complete workflow without external provider writes.
# Change each provider to "live" independently during integration testing.
PASSSLOT_MODE=mock
PASSSLOT_API_KEY=replace_me
PASSSLOT_TEMPLATE_ID=6670122238476288
PASSSLOT_EXPECTED_TYPE_IDENTIFIER=pass.loyalty
PASSSLOT_BALANCE_FIELD=points

SYRVE_MODE=mock
SYRVE_BASE_URL=https://api-eu.syrve.live
SYRVE_API_LOGIN=replace_me
SYRVE_ORGANIZATION_ID=fecb3371-8475-4df5-92c8-4dae76a83a88
SYRVE_GIFT_PROGRAM_ID=0eaa0000-29b3-b8cb-03ac-08dddb2b3534
SYRVE_LOYALTY_PROGRAM_ID=0eaa0000-29b3-b8cb-e946-08ddac10ef86
SYRVE_LOYALTY_PREFIX=syrve
SYRVE_WEBHOOK_SECRET=replace_with_a_long_random_secret

PLANFIX_MODE=disabled
PLANFIX_EVENT_URL=
PLANFIX_API_TOKEN=

FULFILLMENT_DEADLINE_MINUTES=120
WORKER_POLL_SECONDS=2
