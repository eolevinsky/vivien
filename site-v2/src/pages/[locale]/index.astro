---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BookingButton from '../../components/BookingButton.astro';
import MenuSection from '../../components/MenuSection.astro';
import SpecialsSection from '../../components/SpecialsSection.astro';
import EventsSection from '../../components/EventsSection.astro';
import FormShell from '../../components/FormShell.astro';
import { alternatesFor, bookingFormLocale, canonicalUrl, events, getGallery, getMenu, locales, localizedPath, site, specials, t, withBase } from '../../content/site.js';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const copy = t(locale);
const path = localizedPath(locale, 'home');
const bookingLang = bookingFormLocale(locale);
const menu = getMenu(locale);
const gallery = getGallery();
const showEventsSection = events.some((event) => !event.hidden);
const contactHours = copy.home.hoursText.split('\n');
const careerCards = [
  locale === 'en' && {
    href: localizedPath(locale, 'maitre'),
    title: copy.jobs.maitre?.positionValue || copy.jobs.maitreTitle,
    text: 'Orchestrate the dining experience, greet guests with warmth and oversee daily service excellence.',
  },
  {
    href: localizedPath(locale, 'waiter'),
    title: copy.jobs.waiter?.positionValue || copy.jobs.waiterTitle,
    text: locale === 'en'
      ? 'Deliver memorable service with charm, attentiveness, and deep knowledge of our menu and wines.'
      : copy.jobs.intro,
  },
].filter(Boolean);
const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': ['Restaurant', 'LocalBusiness'],
  name: 'Brasserie Vivien',
  url: canonicalUrl(path),
  image: [
    canonicalUrl('/assets/img/hero-7.jpg'),
    canonicalUrl('/assets/img/gallery/1_Vivien_and_Oysters.jpg'),
    canonicalUrl('/assets/img/gallery/3_Wine_Stand.jpg')
  ],
  telephone: site.phone,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Brivibas iela 37',
    addressLocality: 'Riga',
    postalCode: 'LV-1010',
    addressCountry: 'LV'
  },
  servesCuisine: ['French', 'Brasserie', 'Bistro'],
  priceRange: '€€',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Friday'], opens: '17:00', closes: '23:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday', 'Sunday'], opens: '12:00', closes: '23:00' }
  ],
  menu: canonicalUrl(path + '#menu'),
  acceptsReservations: true,
  potentialAction: {
    '@type': 'ReserveAction',
    target: canonicalUrl(`${path}?openBooking=1&lang=${bookingLang}&booking_source=schema_reserve`),
    result: { '@type': 'FoodEstablishmentReservation', name: 'Table reservation' }
  },
  sameAs: site.social
};
---
<BaseLayout locale={locale} title={copy.meta.homeTitle} description={copy.meta.homeDescription} canonicalPath={path} alternates={alternatesFor('home')} schema={restaurantSchema}>
  <Header locale={locale} active="home" kind="home" />
  <main>
    <section class="hero">
      <img src={withBase('/assets/img/hero-7.jpg')} alt="Brasserie Vivien dining room atmosphere" loading="eager" />
      <div class="hero-content">
        <div class="hero-content-card">
          <h1>{copy.home.heroTitleLead} <span>{copy.home.heroBrand}</span></h1>
          <p>{copy.home.heroText}</p>
          <div class="hero-actions">
            <a class="button" href="#menu">{copy.home.menuCta}</a>
            <BookingButton label={copy.home.bookCta} source="home_hero" />
          </div>
          <div class="visit-invite">
            <div class="visit-accent">
              <p>{copy.home.prepareTitle}</p>
              <p>{copy.home.prepareText}</p>
              <div class="visit-action">
                <a class="button" href={site.prepareTableUrl} data-prepare-table>{copy.home.prepareCta}</a>
              </div>
              <div class="visit-note">{copy.home.prepareNote}</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <MenuSection locale={locale} menu={menu} />

    <SpecialsSection locale={locale} copy={copy} specials={specials} />

    {showEventsSection && <EventsSection locale={locale} events={events} />}

    <section class="section gallery-section" id="gallery">
      <div class="section-title">
        <p>{copy.home.galleryTitle}</p>
        <h2>{copy.home.gallerySubtitle}</h2>
      </div>
      <div class="gallery-grid">
        {gallery.map((image) => (
          <a href={withBase(image.src)} target="_blank" rel="noopener">
            <img src={withBase(image.src)} alt={image.alt || 'Brasserie Vivien gallery image'} loading="lazy" width="640" height="640" />
          </a>
        ))}
      </div>
    </section>

    <section class="section careers-section" id="careers">
      <div class="section-title">
        <p>{copy.home.careersTitle}</p>
        <h2>{copy.home.careersSubtitle}</h2>
      </div>
      <div class="job-grid">
        {careerCards.map((job, index) => (
          <article class="job-card">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3><a href={withBase(job.href)}>{job.title}</a></h3>
            <p>{job.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section contact-section" id="contact">
      <div class="section-title">
        <p>{copy.home.contactTitle}</p>
        <h2>{copy.home.contactSubtitle}</h2>
      </div>
      <div class="contact-map">
        <iframe src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d2175.592245611252!2d24.120112!3d56.955786999999994!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2s!5e0!3m2!1sen!2slv!4v1746722439156!5m2!1sen!2slv" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Brasserie Vivien map"></iframe>
      </div>
      <div class="contact-layout">
        <div class="contact-list">
          <div class="contact-info-item">
            <span class="contact-icon contact-icon-location" aria-hidden="true"></span>
            <div><h3>{copy.home.location}</h3><p>Brīvības iela 37, Rīga, LV-1010</p></div>
          </div>
          <div class="contact-info-item">
            <span class="contact-icon contact-icon-hours" aria-hidden="true"></span>
            <div>
              <h3>{copy.home.hours}</h3>
              {contactHours.map((line) => <p>{line}</p>)}
            </div>
          </div>
          <div class="contact-info-item">
            <span class="contact-icon contact-icon-phone" aria-hidden="true"></span>
            <div><h3>{copy.home.call}</h3><p><a href={`tel:${site.phoneHref}`}>{site.phone}</a></p></div>
          </div>
          <div class="contact-info-item">
            <span class="contact-icon contact-icon-email" aria-hidden="true"></span>
            <div><h3>{copy.home.email}</h3><p><a href={`mailto:${site.email}`}>{site.email}</a></p></div>
          </div>
        </div>
        <div class="contact-form-column">
          <FormShell locale={locale} action={withBase('/forms/contact.php')} eventName="contact_submit" submitLabel={copy.home.contactSend || copy.form.send}>
            <div class="row">
              <input type="text" name="name" placeholder={copy.form.name} required />
              <input type="email" name="email" placeholder={copy.form.email} required />
            </div>
            <input type="text" name="subject" placeholder={copy.form.subject} required />
            <textarea name="message" placeholder={copy.form.message} required></textarea>
          </FormShell>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
