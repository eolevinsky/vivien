---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormShell from '../../../components/FormShell.astro';
import { alternatesFor, locales, localizedPath, site, t, withBase } from '../../../content/site.js';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const copy = t(locale);
const path = localizedPath(locale, 'review');
---
<BaseLayout locale={locale} title={`${copy.review.title} | Brasserie Vivien`} description={copy.review.description} canonicalPath={path} alternates={alternatesFor('review')}>
  <Header locale={locale} active="review" kind="review" />
  <main>
    <section class="hero page-hero">
      <img src={withBase('/assets/img/gallery/4_The_Mim.jpg')} alt="Brasserie Vivien guest atmosphere" loading="eager" />
      <div class="hero-content">
        <h1>{copy.review.titleLead} <span>{copy.review.titleHighlight}</span></h1>
        {copy.review.heroLines.map((line) => <p>{line}</p>)}
        <div class="review-source" data-review-source>
          <p class="review-question">{copy.review.visitorQuestion}</p>
          <div class="choice-group" role="group" aria-label={copy.review.visitorQuestion}>
            <button type="button" class="choice-button" data-visitor-value="first_time">{copy.review.firstTime}</button>
            <button type="button" class="choice-button" data-visitor-value="returning">{copy.review.returning}</button>
          </div>
          <div class="source-options" data-source-block hidden data-source-first={copy.review.sourceFirst} data-source-returning={copy.review.sourceReturning}>
            <p class="review-question" data-source-label>{copy.review.sourceFirst}</p>
            <p class="source-hint">{copy.review.sourceHint}</p>
            <div class="choice-group" role="group" aria-label={copy.review.sourceFirst}>
              {copy.review.sources.map((source) => <button type="button" class="choice-button" data-source-value={source}>{source}</button>)}
            </div>
          </div>
          <input type="hidden" name="visitor_type" data-review-visitor-value />
          <input type="hidden" name="source" data-review-source-value />
        </div>
        <div class="hero-actions">
          <button type="button" class="button primary" data-positive-review={withBase('/forms/review_positive.php')} data-google-review-url={site.googleReviewUrl}>{copy.review.positive}</button>
          <a class="button" href="#feedback" data-private-feedback-trigger>{copy.review.negative}</a>
        </div>
      </div>
    </section>
    <section class="section" id="feedback" data-private-feedback hidden tabindex="-1">
      <div class="split">
        <div class="section-title">
          <p>{copy.review.privateTitle}</p>
        </div>
        <div class="panel">
          <FormShell locale={locale} action={withBase('/forms/review.php')} eventName="review_negative" submitLabel={copy.review.submit}>
            <div class="row">
              <input type="text" name="name" placeholder={copy.form.name} />
              <input type="email" name="email" placeholder={copy.form.email} required />
            </div>
            <input type="tel" name="phone" placeholder={copy.form.phone} />
            <textarea name="message" placeholder={copy.review.message} required></textarea>
            <input type="file" name="attachment[]" multiple />
            <input type="hidden" name="visitor_type" data-review-visitor-value />
            <input type="hidden" name="source" data-review-source-value />
            <input type="hidden" name="language_label" value={copy.review.languageName} />
          </FormShell>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
