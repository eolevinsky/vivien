---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormShell from '../../../components/FormShell.astro';
import { alternatesFor, legalLabels, locales, localizedPath, t, withBase } from '../../../content/site.js';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const copy = t(locale);
const path = localizedPath(locale, 'gift');
const giftAmountMin = '10\u00a0€';
const giftAmountMax = '500\u00a0€';
const checkoutAction = 'https://api.vivien.lv/v1/gift-cards/checkout';
const checkoutLabels = {
  en: {
    formTitle: 'Create a Vivien Gift Card',
    firstName: 'Recipient first name',
    lastName: 'Recipient last name',
    recipientEmail: 'Recipient email (optional)',
    birthday: 'Birthday, DD.MM.YYYY (optional)',
    payerEmail: 'Payer email',
    payerNote: 'Note for our team (optional)',
    recipientMessage: 'Message to recipient (optional)',
    submit: 'Continue to Secure Payment',
    cancelled: 'Payment was cancelled. Your card was not charged.',
  },
  lv: {
    formTitle: 'Iegādāties Vivien dāvanu karti',
    firstName: 'Saņēmēja vārds',
    lastName: 'Saņēmēja uzvārds',
    recipientEmail: 'Saņēmēja e-pasts (nav obligāti)',
    birthday: 'Dzimšanas diena, DD.MM.GGGG (nav obligāti)',
    payerEmail: 'Maksātāja e-pasts',
    payerNote: 'Piezīme mūsu komandai (nav obligāti)',
    recipientMessage: 'Ziņa saņēmējam (nav obligāti)',
    submit: 'Turpināt uz drošu maksājumu',
    cancelled: 'Maksājums tika atcelts. No kartes nauda netika noņemta.',
  },
  fr: {
    formTitle: 'Acheter une carte cadeau Vivien',
    firstName: 'Prénom du bénéficiaire',
    lastName: 'Nom du bénéficiaire',
    recipientEmail: 'E-mail du bénéficiaire (facultatif)',
    birthday: 'Date de naissance, JJ.MM.AAAA (facultatif)',
    payerEmail: 'E-mail du payeur',
    payerNote: 'Note pour notre équipe (facultatif)',
    recipientMessage: 'Message au bénéficiaire (facultatif)',
    submit: 'Continuer vers le paiement sécurisé',
    cancelled: 'Le paiement a été annulé. Votre carte n’a pas été débitée.',
  },
  ru: {
    formTitle: 'Купить подарочную карту Vivien',
    firstName: 'Имя получателя',
    lastName: 'Фамилия получателя',
    recipientEmail: 'E-mail получателя (необязательно)',
    birthday: 'Дата рождения, ДД.ММ.ГГГГ (необязательно)',
    payerEmail: 'E-mail плательщика',
    payerNote: 'Комментарий для команды (необязательно)',
    recipientMessage: 'Сообщение получателю (необязательно)',
    submit: 'Перейти к безопасной оплате',
    cancelled: 'Платёж отменён. Деньги с карты не списаны.',
  },
};
const labels = checkoutLabels[locale] || checkoutLabels.en;
---
<BaseLayout locale={locale} title={`${copy.gift.title} | Brasserie Vivien`} description={copy.gift.description} canonicalPath={path} alternates={alternatesFor('gift')}>
  <Header locale={locale} active="gift" kind="gift" />
  <main>
    <section class="hero page-hero">
      <img src={withBase('/assets/img/Hero.jpg')} alt="Brasserie Vivien gift card mood" loading="eager" />
      <div class="hero-content">
        <h1>{copy.gift.titleLead} <span>{copy.gift.titleBrand}</span></h1>
        <p>
          {copy.gift.formatLabel} <strong>Apple / Google Wallet</strong>. {copy.gift.amountPrefix} <strong>{giftAmountMin}</strong> {copy.gift.amountTo} <strong>{giftAmountMax}</strong>. {copy.gift.deliveryLine}
        </p>
        <p>{copy.gift.benefitLead}</p>
        <ul class="hero-list">
          {copy.gift.benefits.map((item) => <li>{item}</li>)}
        </ul>
        <div class="hero-actions">
          <a class="button" href="#giftcard-form">{labels.formTitle}</a>
        </div>
      </div>
    </section>
    <section class="section" id="giftcard-form">
      <div class="split">
        <div>
          <div class="section-title">
            <p>{labels.formTitle}</p>
          </div>
          <p><a href={withBase(localizedPath(locale, 'legal', { legal: 'terms' }))}>{legalLabels.terms[locale]}</a> · <a href={withBase(localizedPath(locale, 'legal', { legal: 'public-offer' }))}>{legalLabels['public-offer'][locale]}</a> · <a href={withBase(localizedPath(locale, 'legal', { legal: 'personal-data-consent' }))}>{legalLabels['personal-data-consent'][locale]}</a></p>
        </div>
        <div class="panel">
          <FormShell locale={locale} action={checkoutAction} eventName="gift_card_checkout_start" submitLabel={labels.submit} checkout={true} cancelledMessage={labels.cancelled}>
            <div class="row">
              <input type="number" min="10" max="500" name="amount" placeholder={copy.gift.amount} required />
              <input type="text" name="recipient_birthday" inputmode="numeric" pattern="[0-9]{2}\.[0-9]{2}\.[0-9]{4}" placeholder={labels.birthday} aria-label={labels.birthday} />
            </div>
            <div class="row">
              <input type="text" name="recipient_first_name" placeholder={labels.firstName} required />
              <input type="text" name="recipient_last_name" placeholder={labels.lastName} required />
            </div>
            <input type="email" name="recipient_email" placeholder={labels.recipientEmail} />
            <input type="email" name="payer_email" placeholder={labels.payerEmail} required />
            <textarea name="payer_note" placeholder={labels.payerNote}></textarea>
            <textarea name="message_to_recipient" placeholder={labels.recipientMessage}></textarea>
            <input type="hidden" name="card_kind" value="gift" />
            <input type="hidden" name="subject" value={`New Vivien Gift Card Order (${locale.toUpperCase()})`} />
          </FormShell>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
