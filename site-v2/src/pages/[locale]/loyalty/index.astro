---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormShell from '../../../components/FormShell.astro';
import { alternatesFor, locales, localizedPath, t, withBase } from '../../../content/site.js';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const copy = t(locale);
const path = localizedPath(locale, 'loyalty');
const checkoutAction =
  import.meta.env.PUBLIC_GIFT_CARD_CHECKOUT_URL || 'https://api.vivien.lv/v1/gift-cards/checkout';
const checkoutLabels = {
  en: {
    amount: 'Starting balance, EUR',
    firstName: 'First name',
    lastName: 'Last name',
    payerEmail: 'Email',
    birthday: 'Birthday, DD.MM.YYYY (optional)',
    note: 'Optional note',
    submit: 'Create Card & Pay Securely',
    cancelled: 'Payment was cancelled. Your card was not charged.',
  },
  lv: {
    amount: 'Sākuma atlikums, EUR',
    firstName: 'Vārds',
    lastName: 'Uzvārds',
    payerEmail: 'E-pasts',
    birthday: 'Dzimšanas diena, DD.MM.GGGG (nav obligāti)',
    note: 'Piezīme (nav obligāti)',
    submit: 'Izveidot karti un droši samaksāt',
    cancelled: 'Maksājums tika atcelts. No kartes nauda netika noņemta.',
  },
  fr: {
    amount: 'Solde initial, EUR',
    firstName: 'Prénom',
    lastName: 'Nom',
    payerEmail: 'E-mail',
    birthday: 'Date de naissance, JJ.MM.AAAA (facultatif)',
    note: 'Note facultative',
    submit: 'Créer la carte et payer',
    cancelled: 'Le paiement a été annulé. Votre carte n’a pas été débitée.',
  },
  ru: {
    amount: 'Начальный баланс, EUR',
    firstName: 'Имя',
    lastName: 'Фамилия',
    payerEmail: 'E-mail',
    birthday: 'Дата рождения, ДД.ММ.ГГГГ (необязательно)',
    note: 'Комментарий (необязательно)',
    submit: 'Создать карту и оплатить',
    cancelled: 'Платёж отменён. Деньги с карты не списаны.',
  },
};
const labels = checkoutLabels[locale] || checkoutLabels.en;
---
<BaseLayout locale={locale} title={`${copy.loyalty.title} | Brasserie Vivien`} description={copy.loyalty.description} canonicalPath={path} alternates={alternatesFor('loyalty')}>
  <Header locale={locale} active="loyalty" kind="loyalty" />
  <main>
    <section class="hero page-hero">
      <img src={withBase('/assets/img/gallery/2_Vivien_at_Work.jpg')} alt="Brasserie Vivien team" loading="eager" />
      <div class="hero-content">
        <p class="kicker">{copy.nav.loyalty}</p>
        <h1>{copy.loyalty.title}</h1>
        <p>{copy.loyalty.description}</p>
      </div>
    </section>
    <section class="section">
      <div class="split">
        <div class="section-title">
          <p>{copy.loyalty.title}</p>
          <h2>{copy.loyalty.description}</h2>
        </div>
        <div class="panel">
          <FormShell locale={locale} action={checkoutAction} eventName="loyalty_checkout_start" submitLabel={labels.submit} checkout={true} cancelledMessage={labels.cancelled}>
            <div class="row">
              <input type="text" name="recipient_first_name" placeholder={labels.firstName} required />
              <input type="text" name="recipient_last_name" placeholder={labels.lastName} required />
            </div>
            <div class="row">
              <input type="email" name="payer_email" placeholder={labels.payerEmail} required />
              <input type="text" name="recipient_birthday" inputmode="numeric" pattern="[0-9]{2}\.[0-9]{2}\.[0-9]{4}" placeholder={labels.birthday} aria-label={labels.birthday} />
            </div>
            <div class="row">
              <input type="number" min="10" max="500" name="amount" placeholder={labels.amount} required />
              <input type="email" name="recipient_email" placeholder={copy.form.email} />
            </div>
            <textarea name="payer_note" placeholder={labels.note}></textarea>
            <input type="hidden" name="card_kind" value="loyalty" />
          </FormShell>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>
