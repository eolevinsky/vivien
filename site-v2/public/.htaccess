Options -Indexes
RewriteEngine On

# Short marketing links. Keep these temporary redirects so campaign targets can
# change without long-lived browser or platform caches.
RewriteRule ^e/?$ /en/?lang=en&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/(en|lv|ru)/?$ /$1/?lang=$1&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/fr/?$ /fr/?lang=en&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/[A-Za-z]{2}/?$ /en/?lang=en&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/(en|lv|ru)/([A-Za-z0-9._~-]+)/?$ /$1/?lang=$1&event=$2&utm_source=shortlink&utm_medium=event&utm_campaign=event_$2#events [R=302,L,NE,QSA]
RewriteRule ^e/fr/([A-Za-z0-9._~-]+)/?$ /fr/?lang=en&event=$1&utm_source=shortlink&utm_medium=event&utm_campaign=event_$1#events [R=302,L,NE,QSA]
RewriteRule ^e/([A-Za-z]{2})/([A-Za-z0-9._~-]+)/?$ /en/?lang=en&event=$2&utm_source=shortlink&utm_medium=event&utm_campaign=event_$2#events [R=302,L,NE,QSA]
RewriteRule ^e/([A-Za-z0-9._~-]+)/?$ /en/?lang=en&event=$1&utm_source=shortlink&utm_medium=event&utm_campaign=event_$1#events [R=302,L,NE,QSA]

