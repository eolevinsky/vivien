Options -Indexes
RewriteEngine On

# BEGIN generated short marketing links
# Generated by scripts/generate-short-links.mjs from scripts/short-links.config.mjs.
# Keep these temporary redirects so campaign targets can change without long-lived caches.
RewriteRule ^e/?$ /en/?lang=en&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/(en|lv|ru)/?$ /$1/?lang=$1&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/fr/?$ /fr/?lang=en&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/[A-Za-z]{2}/?$ /en/?lang=en&utm_source=shortlink&utm_medium=event&utm_campaign=events#events [R=302,L,NE,QSA]
RewriteRule ^e/(en|lv|ru)/(menu|events|gallery|specials|careers|contact)/([A-Za-z0-9._~-]+)/?$ /$1/?lang=$1&utm_source=shortlink&utm_medium=event&utm_campaign=$3&utm_content=section_$2#$2 [R=302,L,NE,QSA]
RewriteRule ^e/fr/(menu|events|gallery|specials|careers|contact)/([A-Za-z0-9._~-]+)/?$ /fr/?lang=en&utm_source=shortlink&utm_medium=event&utm_campaign=$2&utm_content=section_$1#$1 [R=302,L,NE,QSA]
