# Build target. Use "staging" for vivien.lv/_staging/v2/ builds.
VIVIEN_BUILD_TARGET=production
PUBLIC_VIVIEN_BUILD_TARGET=production
VIVIEN_BASE_PATH=/
VIVIEN_SITE_URL=https://vivien.lv

# Consent and analytics. Configure real IDs in Plesk or CI, not in git.
PUBLIC_COOKIEYES_ID=4a5d342324df0e340b2b034917706d78
PUBLIC_GTM_ID=

# Server-side form email transport. No real secrets belong in this repository.
VIVIEN_MAIL_FROM=noreply@vivien.lv
VIVIEN_MAIL_FROM_NAME=Brasserie Vivien
VIVIEN_SMTP_HOST=
VIVIEN_SMTP_PORT=587
VIVIEN_SMTP_USER=
VIVIEN_SMTP_PASS=
VIVIEN_SMTP_SECURE=tls

# Optional ImageKit gallery cache refresh.
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_ENDPOINT=
IMAGEKIT_FOLDER=/vivien.lv
