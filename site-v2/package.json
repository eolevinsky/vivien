{
  "name": "vivien-site-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/fetch-menu.mjs && node scripts/refresh-gallery.mjs",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "build:staging": "ASTRO_TELEMETRY_DISABLED=1 VIVIEN_BUILD_TARGET=staging PUBLIC_VIVIEN_BUILD_TARGET=staging VIVIEN_BASE_PATH=/_staging/v2 astro build",
    "preview": "astro preview",
    "fetch:menu": "node scripts/fetch-menu.mjs",
    "fetch:legal": "node scripts/fetch-legal.mjs",
    "refresh:gallery": "node scripts/refresh-gallery.mjs"
  },
  "dependencies": {
    "astro": "^7.0.1"
  }
}
